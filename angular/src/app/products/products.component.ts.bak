  products: Product[] = [];
  filteredProducts: Product[] = [];
  categories: Category[] = [];
  loading = false;
  
  // Filter properties
  selectedCategory: Category | null = null;
  searchQuery: string = '';
  priceRange: number[] = [0, 5000];
  inStockOnly: boolean = false;

  private apiUrl = 'http://localhost:5000/api/products';

  constructor(private http: HttpClient, private productService: ProductService, private router: Router) {}

  ngOnInit(): void {
    console.log('ProductsComponent initialized');
    this.loadProducts();
    this.loadCategories();
  }

  loadLGProducts(): void {
    this.loading = true;
    this.productService.getProducts().subscribe({
      next: (response) => {
        console.log('API Response:', response);
        // Map response to match Product interface
        this.products = (response.items || []).map((item: any) => ({
          id: item.id,
          productCode: item.productCode || item.itemCode,
          productName: item.productName || item.itemName,
          description: item.description,
          brand: item.brand || '',
          model: item.model || '',
          category: item.category,
          subCategory: item.subCategory || '',
          specifications: item.specifications || '',
          dimensions: item.dimensions || '',
          weight: item.weight || 0,
          color: item.color || '',
          material: item.material || '',
          costPrice: item.costPrice || item.unitCost || 0,
          sellingPrice: item.sellingPrice || item.unitPrice || 0,
          retailPrice: item.retailPrice || item.sellingPrice || item.unitPrice || 0,
          currentStock: item.currentStock || item.quantity || 0,
          imageUrls: item.imageUrls || '[]',
          tags: item.tags || '',
          status: item.status || 1,
          sku: item.sku || item.itemCode || '',
          creationTime: item.creationTime || new Date().toISOString()
        }));
        console.log('Mapped products:', this.products);
        this.filteredProducts = this.products;
        this.loading = false;
      },
      error: (error) => {
        console.error('Error loading products:', error);
        this.loading = false;
        // Fallback to demo data if API fails
        this.loadDemoData();
      }
    });
  }

  loadCategories(): void {
    this.productService.getProductCategories().subscribe({
      next: (data) => {
        this.categories = data.map(cat => ({ name: cat, value: cat }));
      },
      error: (error) => {
        console.error('Error loading categories:', error);
        // Fallback categories
        this.categories = [
          { name: 'TVs', value: 'TVs' },
          { name: 'Refrigerators', value: 'Refrigerators' },
          { name: 'Laptops', value: 'Laptops' },
          { name: 'Washing Machines', value: 'Washing Machines' },
          { name: 'Dryers', value: 'Dryers' },
          { name: 'Audio', value: 'Audio' },
          { name: 'Air Conditioners', value: 'Air Conditioners' }
        ];
      }
    });
  }

